<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface"
    tools:context=".AddDestinationActivity">

    <!-- AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        android:theme="@style/Theme.Material3.DayNight.NoActionBar">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:contentInsetStart="0dp"
            app:contentInsetEnd="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_arrow_back"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:text="Agregar destino"
                    android:textColor="@color/primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/btnBack"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="Gestiona tu próximo"
                android:textColor="@color/on_surface"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-4dp"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="Destino"
                android:textColor="@color/primary"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Agrega un nuevo capítulo en Trip."
                android:textColor="@color/text_muted"
                android:textSize="16sp" />

            <!-- Cover Imagery -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:letterSpacing="0.05"
                android:text="IMAGEN DE PORTADA"
                android:textAllCaps="true"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/imageContainer"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_upload_box">
                <!-- Using surface_container_highest with light grey placeholder vibe -->

                <ImageView
                    android:id="@+id/ivCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <LinearLayout
                    android:id="@+id/llUploadPrompt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">
                    
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_circle_icon"
                        android:src="@drawable/ic_camera"
                        android:padding="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/plus_jakarta_sans_bold"
                        android:text="Subir imagen"
                        android:textColor="@color/primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/plus_jakarta_sans_medium"
                        android:text="PNG, JPG hasta 10MB"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Destination Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:letterSpacing="0.05"
                android:text="NOMBRE DE DESTINO"
                android:textAllCaps="true"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etDestinationName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_field"
                android:fontFamily="@font/plus_jakarta_sans"
                android:hint="p.ej. Santorini Sunsets"
                android:inputType="textCapWords"
                android:paddingHorizontal="16dp"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/text_muted"
                android:textSize="16sp" />

            <!-- Country -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:letterSpacing="0.05"
                android:text="PAIS"
                android:textAllCaps="true"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_field">

                <AutoCompleteTextView
                    android:id="@+id/etDestinationCountry"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:hint="p.ej. Grecia"
                    android:inputType="none"
                    android:focusable="false"
                    android:clickable="true"
                    android:background="@null"
                    android:textColor="@color/on_surface"
                    android:textSize="16sp"
                    app:layout_constraintEnd_toStartOf="@id/ivDropdown"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageView
                    android:id="@+id/ivDropdown"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_chevron_down"
                    android:paddingEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Price and Duration row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp"
                android:baselineAligned="false">

                <!-- Price -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans_bold"
                        android:letterSpacing="0.05"
                        android:text="PRECIO EST. (USD)"
                        android:textAllCaps="true"
                        android:textColor="@color/on_surface"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etDestinationPrice"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input_field"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:hint="$ 0.00"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/text_muted"
                        android:textSize="16sp" />
                </LinearLayout>

                <!-- Duration -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans_bold"
                        android:letterSpacing="0.05"
                        android:text="DURACION"
                        android:textAllCaps="true"
                        android:textColor="@color/on_surface"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etDestinationDuration"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input_field"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:hint="p.ej. 7 días"
                        android:inputType="text"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/text_muted"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Highlights -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:letterSpacing="0.05"
                android:text="ASPECTOS DESTACADOS DEL VIAJE"
                android:textAllCaps="true"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etDestinationHighlights"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_field"
                android:fontFamily="@font/plus_jakarta_sans"
                android:gravity="top|start"
                android:hint="Describe el ambiente, gemas ocultas, y sitios que debes ver..."
                android:inputType="textMultiLine"
                android:padding="16dp"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/text_muted"
                android:textSize="16sp" />

            <!-- Info Box -->

            <!-- Save Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSaveDestination"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="48dp"
                android:background="@drawable/bg_btn_primary"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="Guardar cambios"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_cloud_upload"
                android:paddingStart="48dp"
                android:drawablePadding="-32dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>